        <!-- Sign Up Path -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;" edge="1" parent="1" source="showLogin" target="signUpTab">
          <mxGeometry relative="1" as="geometry"/>
