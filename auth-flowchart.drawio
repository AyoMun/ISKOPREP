        <mxCell id="e15" value="VALID" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;fontSize=10;fontStyle=1" edge="1" parent="1" source="validateSignUp" target="firebaseSignUp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e16" value="INVALID" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=0;html=1;fontSize=10;fontStyle=1;dashed=1" edge="1" parent="1" source="validateSignUp" target="signUpError">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;" edge="1" parent="1" source="firebaseSignUp" target="updateProfile">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e18" value="SUCCESS" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;fontSize=10;fontStyle=1" edge="1" parent="1" source="updateProfile" target="signUpSuccess">
          <mxGeometry relative="1" as="geometry"/>
