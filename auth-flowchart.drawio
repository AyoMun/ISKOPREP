        <mxCell id="e19" value="ERROR" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=0;html=1;fontSize=10;fontStyle=1;dashed=1" edge="1" parent="1" source="firebaseSignUp" target="signUpError">
