        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;" edge="1" parent="1" source="checkAuth" target="userFound">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e3" value="YES" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=0;html=1;fontSize=11;fontStyle=1" edge="1" parent="1" source="userFound" target="loadApp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e4" value="NO" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;rounded=0;html=1;fontSize=11;fontStyle=1" edge="1" parent="1" source="userFound" target="showLogin">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Sign In Path -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;" edge="1" parent="1" source="showLogin" target="signInTab">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;" edge="1" parent="1" source="signInTab" target="enterCredsSignIn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;" edge="1" parent="1" source="enterCredsSignIn" target="validateSignIn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e8" value="VALID" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;fontSize=10;fontStyle=1" edge="1" parent="1" source="validateSignIn" target="firebaseSignIn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e9" value="INVALID" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=0;html=1;fontSize=10;fontStyle=1;dashed=1" edge="1" parent="1" source="validateSignIn" target="signInError">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e10" value="SUCCESS" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;html=1;fontSize=10;fontStyle=1" edge="1" parent="1" source="firebaseSignIn" target="signInSuccess">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="e11" value="ERROR" style="edgeStyle=orthogonalEdgeStyle;orthogonal=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=0;html=1;fontSize=10;fontStyle=1;dashed=1" edge="1" parent="1" source="firebaseSignIn" target="signInError">
          <mxGeometry relative="1" as="geometry"/>
